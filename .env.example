# ── Server ──────────────────────────────────────────────────
# Self-hosted Postgres (see HOMELAB-DEPLOY.md). For a hosted DB, use its URL.
DATABASE_URL=postgresql://budget:password@localhost:5432/budget
DATABASE_SSL=false                 # true only if your Postgres requires TLS

JWT_SECRET=replace-with-a-random-256-bit-secret
JWT_EXPIRES_IN=7d
ADMIN_PASSWORD=replace-with-a-long-passphrase

PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=production               # sandbox | production
# Public URL of your deployed server + /api/plaid/webhook — enables live transaction pushes
PLAID_WEBHOOK_URL=

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

PORT=3001
CLIENT_URL=http://localhost:5173   # in production, your public hostname (for CORS)

# ── Client (prefix with VITE_) ───────────────────────────────
# Leave blank: the Express server serves the built client on the same origin.
VITE_API_URL=
